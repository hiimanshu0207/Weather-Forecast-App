{
  "version": 2,
  "builds": [
    { "src": "server/server.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server/server.js" },
    { "src": "/(.*\\.(?:js|css|svg|json|png|ico|woff2?))", "dest": "public/$1" },
    { "src": "/(.*)", "dest": "public/index.html" }
  ]
}
